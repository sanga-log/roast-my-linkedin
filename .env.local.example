# Gemini API Key (무료)
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key

# RapidAPI Key
# https://rapidapi.com 에서 발급
RAPIDAPI_KEY=your_rapidapi_key

# Sentry (에러 모니터링)
# https://sentry.io 에서 프로젝트 생성 후 DSN 복사
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your_org
SENTRY_PROJECT=your_project

# Slack Webhook (사용자 이용 로그)
SLACK_WEBHOOK_USER_LOG=https://hooks.slack.com/services/xxx/xxx/xxx
